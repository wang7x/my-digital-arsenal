{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Digital Arsenal Toolchain Schema",
  "type": "object",
  "required": ["type","name",  "language", "license", "tags", "added_date"],
  "properties": {
    "type": { "const": "toolchain" },
    "name": { "type": "string" , "description": "Unique identifier for the tool"},
    "language": { "type": "string" , "description": "Primary development language"},
    "license": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "added_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
  }
}